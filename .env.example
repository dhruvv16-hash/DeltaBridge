# Delta Exchange Webhook Bot - Environment Variables Example
# Copy this file to a new file named .env and fill in your actual credentials.

# 1. Delta Exchange API Keys (Generate from Settings -> API Keys on Delta)
DELTA_API_KEY=your_delta_api_key_here
DELTA_API_SECRET=your_delta_api_secret_here

# 2. Base Endpoint URL
# Use: https://api.delta.exchange (Global Live)
# Use: https://api.india.delta.exchange (India Live)
# Use: https://api.testnet.delta.exchange (Testnet / Paper Trading)
DELTA_BASE_URL=https://api.delta.exchange

# 3. Security Passphrase
# Choose a strong passphrase here. You MUST paste the exact same passphrase in your TradingView alert message.
PASSPHRASE=my_secure_trading_passphrase_123

# 4. Leverage Configuration (e.g. 50 for 50x leverage)
DEFAULT_LEVERAGE=50

# 5. Sizing Safety Buffer (e.g. 95 means allocating 95% of available margin, leaving 5% for fees/slippage)
BALANCE_BUFFER_PCT=95

# 6. Trading Symbol / Asset (e.g. BTCUSD.P, SOLUSD.P)
TRADING_SYMBOL=
